# Dependencies
node_modules/

# Build output
dist/
build/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
vite-dev.out.log
vite-dev.err.log

# Environment files
.env
.env.*
!.env.example

# Paid PDF products - these must never be committed to git.
# They are uploaded directly to Cloudflare R2, not shipped in the repo.
/PDFs/

# Internal setup/architecture notes - not secrets themselves, but no
# reason to publish infrastructure details (bucket names, env var names,
# IAM role names) in the repo. Keep these local only. Any .md file created
# directly inside admin/ is treated as an internal note by default - never
# committed/pushed, regardless of what it's named.
admin/*.md

# Tooling cache
.cache/
.vite/
coverage/
*.tsbuildinfo

# Editor and OS files
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~

# Local Netlify folder
.netlify
deno.lock

# Claude Code local-only settings (tool-permission approvals, machine-
# specific) - launch.json stays tracked (dev-server configs, safe to share),
# but this file should never end up in a commit even via a wildcard `git add`.
.claude/settings.local.json
